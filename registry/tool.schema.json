{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PARA Tool Manifest",
  "description": "Validates tool.manifest.yml files for PARA Workspace tool plugins.",
  "type": "object",
  "required": ["name", "version", "runtime", "entry", "description"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Full tool name (e.g., 'para-graph').",
      "pattern": "^para-[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the tool.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
    },
    "runtime": {
      "type": "string",
      "description": "Required runtime environment.",
      "enum": ["node", "python", "binary"]
    },
    "min_runtime_version": {
      "type": "string",
      "description": "Minimum required version of the runtime.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "entry": {
      "type": "string",
      "description": "Entry point relative to tarball root (e.g., 'dist/cli.js')."
    },
    "description": {
      "type": "string",
      "description": "Short human-readable description of the tool.",
      "maxLength": 200
    },
    "repo": {
      "type": "string",
      "description": "Full URL to the tool's GitHub repository.",
      "pattern": "^https://github\\.com/"
    },
    "agents": {
      "type": "object",
      "description": "Bundled AI intelligence (workflows, skills, rules) distributed with the tool.",
      "properties": {
        "workflows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target", "version"],
            "properties": {
              "source": { "type": "string", "description": "Path relative to tool root." },
              "target": { "type": "string", "description": "Filename in .agents/workflows/." },
              "version": { "type": "string", "description": "Semantic version of this workflow." }
            }
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target", "version"],
            "properties": {
              "source": { "type": "string", "description": "Directory path relative to tool root." },
              "target": { "type": "string", "description": "Directory name in .agents/skills/." },
              "version": { "type": "string", "description": "Semantic version of this skill." }
            }
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target", "version"],
            "properties": {
              "source": { "type": "string", "description": "Path relative to tool root." },
              "target": { "type": "string", "description": "Filename in .agents/rules/." },
              "version": { "type": "string", "description": "Semantic version of this rule." }
            }
          }
        }
      }
    },
    "mcp": {
      "type": "object",
      "description": "MCP Server configuration bundled with the tool. Parsed by mcp-setup command.",
      "required": ["server_name", "transport", "serve_args"],
      "properties": {
        "server_name": {
          "type": "string",
          "description": "MCP server name used as key in IDE config (e.g., 'para-graph').",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "transport": {
          "type": "string",
          "description": "Transport protocol for MCP communication.",
          "enum": ["stdio"]
        },
        "serve_args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Arguments appended after entry point. Supports ${WORKSPACE_ROOT} placeholder."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the MCP server capabilities.",
          "maxLength": 200
        }
      }
    }
  }
}
