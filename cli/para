#!/bin/bash

# PARA Workspace CLI
# Usage: ./cli/para [command] [args...]
# Version: 1.4.9

set -e

# Resolve CLI directory relative to this script
CLI_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMANDS_DIR="$CLI_DIR/commands"

# Workspace Root detection
if [ -f ".para-workspace.yml" ]; then
  WORKSPACE_ROOT="$(pwd)"
elif [ -f "../../.para-workspace.yml" ]; then
  WORKSPACE_ROOT="$(realpath ../..)"
else
  WORKSPACE_ROOT="$(pwd)"
fi
export WORKSPACE_ROOT

# Version
VERSION="$(cat "$CLI_DIR/../VERSION" 2>/dev/null || echo "1.4.1")"

case "$1" in
  init)
    shift
    "$COMMANDS_DIR/init.sh" "$@"
    ;;
  scaffold)
    shift
    "$COMMANDS_DIR/scaffold.sh" "$@"
    ;;
  status)
    shift
    "$COMMANDS_DIR/status.sh" "$@"
    ;;
  migrate)
    shift
    "$COMMANDS_DIR/migrate.sh" "$@"
    ;;
  archive)
    shift
    "$COMMANDS_DIR/archive.sh" "$@"
    ;;
  install)
    shift
    "$COMMANDS_DIR/install.sh" "$@"
    ;;
  config)
    shift
    "$COMMANDS_DIR/config.sh" "$@"
    ;;
  plan)
    shift
    "$COMMANDS_DIR/plan.sh" "$@"
    ;;
  review)
    shift
    "$COMMANDS_DIR/review.sh" "$@"
    ;;
  verify)
    shift
    "$COMMANDS_DIR/verify.sh" "$@"
    ;;
  update)
    shift
    "$COMMANDS_DIR/update.sh" "$@"
    ;;
  cleanup)
    shift
    "$COMMANDS_DIR/cleanup.sh" "$@"
    ;;
  work)
    shift
    "$COMMANDS_DIR/workflow.sh" "$@"
    ;;
  rule)
    shift
    "$COMMANDS_DIR/rule.sh" "$@"
    ;;
  test)
    shift
    echo "🧪 Running PARA Kernel Tests..."
    echo ""
    bash "$CLI_DIR/../tests/kernel/test-schemas.sh"
    echo ""
    bash "$CLI_DIR/../tests/kernel/test-invariants.sh"
    ;;
  version|-v|--version)
    echo "PARA Workspace v$VERSION"
    ;;
  help|--help|-h|*)
    echo "PARA Workspace CLI v$VERSION"
    echo ""
    echo "Usage: para <command> [args...]"
    echo ""
    echo "━━━ Core Commands ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  init [--profile=X] [--lang=X]     Create a new workspace"
    echo "       --profile=NAME               Workspace preset (general, dev, marketer, ceo)"
    echo "       --lang=CODE                  Language (en, vi)"
    echo "       --path=DIR                   Target directory"
    echo ""
    echo "  scaffold <type> <name>            Create project, area, or resource"
    echo "       type: project | area | resource"
    echo ""
    echo "  status [--json]                   Show workspace health & stats"
    echo "  archive <type>/<name> [--force]   Move item to Archive/"
    echo ""
    echo "━━━ Sync & Upgrade ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  update [--dry-run]                Pull latest repo + re-sync workspace"
    echo "  install [--force] [--dry-run]      Sync kernel, workflows, rules, skills"
    echo "       --force                      Overwrite all, even if local is newer"
    echo "       --dry-run                    Preview changes without applying"
    echo "  cleanup [--dry-run] [--force]      Remove old backups and legacy .bak files"
    echo "       --keep=N                     Keep N most recent backup days (default: 5)"
    echo ""
    echo "  migrate [--from=X] [--to=Y]       Migrate workspace to new version"
    echo "       --dry-run                    Preview changes without applying"
    echo ""
    echo "━━━ Dev Commands ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  plan <project> <desc>             Create implementation plan"
    echo "  verify <project> [desc]           Create/list walkthroughs"
    echo "  review                            Deep workspace audit"
    echo ""
    echo "━━━ System Commands ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  config [key] [value]              Get/set workspace config"
    echo "  work <command>                    Manage workflows (list/add/remove)"
    echo "  rule <command>                    Manage rules (list/add/remove)"
    echo "  test                              Run kernel test suite"
    echo "  version                           Show CLI version"
    echo ""
    echo "━━━ Examples ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  para init --profile=dev --lang=en"
    echo "  para scaffold project my-saas-app"
    echo "  para status --json"
    echo "  para update"
    echo "  para migrate --from=1.4.0 --to=1.4.1 --dry-run"
    echo ""
    echo "Docs: https://github.com/pageel/para-workspace"
    exit 1
    ;;
esac
