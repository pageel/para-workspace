#!/bin/bash

# PARA Workspace CLI
# Usage: ./cli/para [command] [args...]
# Version: 1.9.5
# Kernel Version: 1.4

set -e

# Resolve CLI directory relative to this script
CLI_DIR="$(cd "$(dirname "$0")" && pwd)"
COMMANDS_DIR="$CLI_DIR/commands"

# Workspace Root detection (R7: Fail Fast — no blind pwd fallback)
if [ -f ".para-workspace.yml" ]; then
  WORKSPACE_ROOT="$(pwd)"
elif [ -f "../../.para-workspace.yml" ]; then
  WORKSPACE_ROOT="$(realpath ../..)"
else
  # Only allow pwd fallback for 'init' command (creating new workspace)
  if [ "$1" = "init" ]; then
    WORKSPACE_ROOT="$(pwd)"
  else
    echo "❌ Error: Not a PARA Workspace." >&2
    echo "   Could not find .para-workspace.yml in current or parent directory." >&2
    echo "   Run 'para init' to create a new workspace, or cd to a workspace root." >&2
    exit 1
  fi
fi
export WORKSPACE_ROOT

# Version
VERSION="$(cat "$CLI_DIR/../VERSION" 2>/dev/null || echo "1.4.1")"

case "$1" in
  init)
    shift
    "$COMMANDS_DIR/init.sh" "$@"
    ;;
  scaffold)
    shift
    "$COMMANDS_DIR/scaffold.sh" "$@"
    ;;
  status)
    shift
    "$COMMANDS_DIR/status.sh" "$@"
    ;;
  migrate)
    shift
    "$COMMANDS_DIR/migrate.sh" "$@"
    ;;
  archive)
    shift
    "$COMMANDS_DIR/archive.sh" "$@"
    ;;
  install)
    shift
    "$COMMANDS_DIR/install.sh" "$@"
    ;;
  config)
    shift
    "$COMMANDS_DIR/config.sh" "$@"
    ;;
  plan)
    shift
    "$COMMANDS_DIR/plan.sh" "$@"
    ;;
  review)
    shift
    "$COMMANDS_DIR/review.sh" "$@"
    ;;
  verify)
    shift
    "$COMMANDS_DIR/verify.sh" "$@"
    ;;
  update)
    shift
    "$COMMANDS_DIR/update.sh" "$@"
    ;;
  cleanup)
    shift
    "$COMMANDS_DIR/cleanup.sh" "$@"
    ;;
  work)
    shift
    "$COMMANDS_DIR/workflow.sh" "$@"
    ;;
  rule)
    shift
    "$COMMANDS_DIR/rule.sh" "$@"
    ;;
  test)
    shift
    echo "🧪 Running PARA Kernel Tests..."
    echo ""
    bash "$CLI_DIR/../tests/kernel/test-schemas.sh"
    echo ""
    bash "$CLI_DIR/../tests/kernel/test-invariants.sh"
    ;;
  # ━━━ Tool Management ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  install-tool)
    shift; "$COMMANDS_DIR/install-tool.sh" "$@"
    ;;
  remove-tool)
    shift; "$COMMANDS_DIR/remove-tool.sh" "$@"
    ;;
  list-tools)
    shift; "$COMMANDS_DIR/list-tools.sh" "$@"
    ;;
  # ━━━ MCP Management ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  mcp-setup)
    shift; "$COMMANDS_DIR/mcp-setup.sh" "$@"
    ;;
  mcp-list)
    shift; "$COMMANDS_DIR/mcp-list.sh" "$@"
    ;;
  mcp-remove)
    shift; "$COMMANDS_DIR/mcp-remove.sh" "$@"
    ;;
  version|-v|--version)
    echo "PARA Workspace v$VERSION"
    ;;
  help|--help|-h|"")
    echo "PARA Workspace CLI v$VERSION"
    echo ""
    echo "Usage: para <command> [args...]"
    echo ""
    echo "━━━ Core Commands ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  init [--profile=X] [--lang=X]     Create a new workspace"
    echo "       --profile=NAME               Workspace preset (general, dev)"
    echo "       --lang=CODE                  Language (en, vi)"
    echo "       --path=DIR                   Target directory"
    echo ""
    echo "  scaffold <type> <name>            Create project, area, or resource"
    echo "       type: project | area | resource"
    echo ""
    echo "  status [--json]                   Show workspace health & stats"
    echo "  archive <type>/<name> [--force]   Move item to Archive/"
    echo ""
    echo "━━━ Sync & Upgrade ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  update [--dry-run]                Pull latest repo + re-sync workspace"
    echo "  install [--force] [--dry-run]      Sync kernel, workflows, rules, skills"
    echo "       --force                      Overwrite all, even if local is newer"
    echo "       --dry-run                    Preview changes without applying"
    echo "  cleanup [--dry-run] [--force]      Remove old backups and legacy .bak files"
    echo "       --keep=N                     Keep N most recent backup days (default: 5)"
    echo ""
    echo "  migrate [--from=X] [--to=Y]       Migrate workspace to new version"
    echo "       --dry-run                    Preview changes without applying"
    echo ""
    echo "━━━ Tool Management ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  install-tool <name> [--version=X]  Install a PARA tool plugin"
    echo "  remove-tool <name> [--force]       Remove an installed tool"
    echo "  list-tools [--json]                List installed tools"
    echo ""
    echo "━━━ MCP Management ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  mcp-setup <name> [--ide=X]         Configure MCP server for an IDE"
    echo "       --print-only                  Print JSON config without writing"
    echo "  mcp-list [--json]                  List MCP-capable tools"
    echo "  mcp-remove <name> [--ide=X]        Remove MCP server from IDE config"
    echo ""
    echo "━━━ Dev Commands ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  plan <project> <desc>             Create implementation plan"
    echo "  verify <project> [desc]           Create/list walkthroughs"
    echo "  review                            Deep workspace audit"
    echo ""
    echo "━━━ System Commands ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  config [key] [value]              Get/set workspace config"
    echo "  work <command>                    Manage workflows (list/add/remove)"
    echo "  rule <command>                    Manage rules (list/add/remove)"
    echo "  test                              Run kernel test suite"
    echo "  version                           Show CLI version"
    echo ""
    echo "━━━ Examples ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  para init --profile=dev --lang=en"
    echo "  para scaffold project my-saas-app"
    echo "  para status --json"
    echo "  para update"
    echo "  para install-tool para-graph"
    echo "  para migrate --from=1.4.0 --to=1.4.1 --dry-run"
    echo ""
    echo "Docs: https://github.com/pageel/para-workspace"
    exit 0
    ;;
  *)
    # Prevent mistaking slash commands (workflows) for CLI commands (v1.9.2)
    case "$1" in
      staging|open|end|brainstorm|qa|spec)
        echo "❌ Error: '$1' is a platform workflow, not a CLI command." >&2
        echo "   Please use the slash command equivalent in the chat UI: /$1" >&2
        echo "   Do NOT attempt to execute workflows via terminal commands." >&2
        exit 1
        ;;
    esac

    # Dynamic tool routing — check if auto-generated wrapper script exists
    if [ -f "$COMMANDS_DIR/$1.sh" ]; then
      CMD="$1"; shift; "$COMMANDS_DIR/$CMD.sh" "$@"
    else
      echo "❌ Error: Unknown command '$1'" >&2
      echo "   Run './para --help' for available commands." >&2
      exit 1
    fi
    ;;
esac
